VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# When opening via Akomanga dev proxy: npm run dev:shell or VITE_APP_BASE=/mata/
# Vercel (Mata project): set VITE_APP_BASE=/mata/ on Production and Preview builds.

# Products menu: when this deployment has its own *.vercel.app host, set shell origin so links hit Akomanga.
# VITE_ECOSYSTEM_SHELL_ORIGIN=https://akomanga.vercel.app

# Local-only fallback when Mata is opened without an akomanga launch URL
VITE_DEV_CLASS_ID=2
VITE_DEV_LESSON_NUMBER=1

# Supabase Edge Function secrets for LiveKit Cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
